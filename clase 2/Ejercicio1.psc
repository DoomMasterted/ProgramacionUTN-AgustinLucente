Algoritmo Ejercicio1
    Definir calor_madokita_celsius, fuego_homura_fahrenheit, frio_kyubey_kelvin Como Real
    
    Escribir "Ingresa la temperatura en Celsius: "
    Leer calor_madokita_celsius
    
    // Conversiones
    fuego_homura_fahrenheit <- (calor_madokita_celsius * 9/5) + 32
    frio_kyubey_kelvin <- calor_madokita_celsius + 273.15
    
    Escribir "Temperatura en Fahrenheit: ", fuego_homura_fahrenheit
    Escribir "Temperatura en Kelvin: ", frio_kyubey_kelvin
FinAlgoritmo